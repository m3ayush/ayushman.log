# ── Supabase ───────────────────────────────────────────────
# Create a free project at https://supabase.com, then copy these from
# Project Settings → Data API / API Keys.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Admin ──────────────────────────────────────────────────
# The ONLY email allowed to sign in and write posts. Everyone else is
# read-only. Must match the email you use for the magic-link login.
ADMIN_EMAIL=you@example.com

# ── App ────────────────────────────────────────────────────
# Public base URL — used for magic-link redirects, RSS, and share links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
